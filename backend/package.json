{
  "name": "pawwell-backend-node",
  "version": "1.0.0",
  "description": "PawWell Care Center Backend - Node.js/Express API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node migrations/migrate.js",
    "db:init": "node scripts/initDb.js",
    "db:seed": "node scripts/seedUsers.js",
    "db:seed-admin": "node scripts/seedAdmin.js",
    "db:setup": "npm run db:init && npm run db:seed",
    "render-build": "cd ../frontend && npm install --include=dev && npm run build && cd ../backend && npm install"
  },
  "keywords": [
    "express",
    "api",
    "authentication",
    "jwt",
    "sequelize",
    "postgresql"
  ],
  "author": "PawWell Care Center",
  "license": "MIT",
  "dependencies": {
    "@langchain/community": "^1.1.22",
    "@langchain/core": "^1.1.30",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "groq-sdk": "^1.1.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.2.29",
    "groq-sdk": "^0.3.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "qrcode": "^1.5.4",
    "sequelize": "^6.35.2",
    "speakeasy": "^2.0.0",
    "uuid": "^9.0.1",
    "zod": "^4.3.6",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@prisma/config": "^7.2.0",
    "nodemon": "^3.0.2",
    "prisma": "^7.4.0"
  }
}
