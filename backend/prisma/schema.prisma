generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model activity_logs {
  activity_id   Int       @id @default(autoincrement())
  user_id       Int
  activity_type String    @db.VarChar(100)
  timestamp     DateTime  @db.Timestamptz(6)
  detail        String?
  ip_address    String?   @db.VarChar(45)
  user_agent    String?
  pet_id        Int?
  photo         String?   @db.VarChar(500)
  notify_owner  Boolean?  @default(false)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)
  pets          pets?     @relation(fields: [pet_id], references: [pet_id], onDelete: Cascade, onUpdate: NoAction)
  users         users     @relation(fields: [user_id], references: [id], onDelete: NoAction)
}

model bookings {
  booking_id        Int                         @id @default(autoincrement())
  user_id           Int
  pet_id            Int
  service_id        Int?
  service_type      String                      @db.VarChar(100)
  price             Decimal                     @db.Decimal(10, 2)
  status            enum_bookings_status        @default(pending)
  booking_status    enum_bookings_booking_status @default(pending)
  payment_status    enum_bookings_payment_status @default(unpaid)
  payment_method    String?                     @db.VarChar(50)
  transaction_id    String?                     @db.VarChar(255)
  pidx              String?                     @db.VarChar(255)
  confirmation_code String?                    @unique @db.VarChar(50)
  created_at        DateTime                    @db.Timestamptz(6)
  updated_at        DateTime                    @db.Timestamptz(6)
  start_date        DateTime                    @default(now()) @db.Timestamptz(6)
  end_date          DateTime?                   @db.Timestamptz(6)
  number_of_days    Int                         @default(1)
  requires_pickup   Boolean                     @default(false)
  pickup_address    String?                     @db.VarChar(500)
  pickup_time       String?                     @db.VarChar(50)
  dropoff_address   String?                     @db.VarChar(500)
  dropoff_time      String?                     @db.VarChar(50)
  pets              pets                        @relation(fields: [pet_id], references: [pet_id], onDelete: Cascade)
  services          services?                   @relation(fields: [service_id], references: [service_id])
  users             users                       @relation(fields: [user_id], references: [id], onDelete: NoAction)
  payments          payments?
  reviews           reviews?
}

model emergency_requests {
  emergency_id   Int                            @id @default(autoincrement())
  user_id        Int
  pet_id         Int
  emergency_type String                         @db.VarChar(100)
  contact_info   String                         @db.VarChar(255)
  date           DateTime                       @db.Timestamptz(6)
  status         enum_emergency_requests_status @default(pending)
  created_at     DateTime                       @db.Timestamptz(6)
  updated_at     DateTime                       @db.Timestamptz(6)
  description    String?
  pets           pets                           @relation(fields: [pet_id], references: [pet_id], onDelete: Cascade)
  users          users                          @relation(fields: [user_id], references: [id], onDelete: NoAction)
}

model password_resets {
  id               Int       @id @default(autoincrement())
  user_id          Int
  token            String?   @unique @db.Uuid
  is_used          Boolean?  @default(false)
  expires_at       DateTime  @db.Timestamptz(6)
  created_at       DateTime? @db.Timestamptz(6)
  otp_hash         String?   @db.VarChar(255)
  otp_attempts     Int?      @default(0)
  max_otp_attempts Int?      @default(5)
  is_verified      Boolean?  @default(false)
  users            users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model email_verifications {
  id               Int       @id @default(autoincrement())
  user_id          Int
  otp_hash         String    @db.VarChar(255)
  otp_attempts     Int       @default(0)
  max_otp_attempts Int       @default(5)
  is_verified      Boolean   @default(false)
  expires_at       DateTime  @db.Timestamptz(6)
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  updated_at       DateTime? @default(now()) @db.Timestamptz(6)
  users            users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model payments {
  payment_id          Int       @id @default(autoincrement())
  booking_id          Int       @unique
  amount              Decimal   @db.Decimal(10, 2)
  payment_method      String    @db.VarChar(50)
  transaction_details String?
  payment_date        DateTime  @db.Timestamptz(6)
  created_at          DateTime  @db.Timestamptz(6)
  updated_at          DateTime  @db.Timestamptz(6)
  bookings            bookings  @relation(fields: [booking_id], references: [booking_id], onDelete: Cascade)
  receipts            receipts?
}

model pets {
  pet_id             Int                  @id @default(autoincrement())
  user_id            Int
  name               String               @db.VarChar(100)
  breed              String               @db.VarChar(100)
  age                Int
  weight             Decimal              @db.Decimal(5, 2)
  medical_history    String?
  photo              String               @db.VarChar(500)
  created_at         DateTime             @db.Timestamptz(6)
  updated_at         DateTime             @db.Timestamptz(6)
  height             Decimal?             @db.Decimal(5, 2)
  sex                String?              @db.VarChar(10)
  allergies          String?
  triggering_point   String?
  last_vet_visit     DateTime?            @db.Timestamptz(6)
  deleted_at         DateTime?            @db.Timestamp(6)
  activity_logs      activity_logs[]
  bookings           bookings[]
  emergency_requests emergency_requests[]
  users              users                @relation(fields: [user_id], references: [id], onDelete: NoAction)
  wellness_timeline  wellness_timeline[]
  reviews            reviews[]
}

model public_forum {
  forum_id   Int      @id @default(autoincrement())
  user_id    Int
  title      String   @db.VarChar(255)
  content    String
  post_date  DateTime @db.Timestamptz(6)
  likes      Int      @default(0)
  created_at DateTime @db.Timestamptz(6)
  updated_at DateTime @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: NoAction)
}

model receipts {
  receipt_id   Int      @id @default(autoincrement())
  payment_id   Int      @unique
  receipt_date DateTime @db.Timestamptz(6)
  details      String?
  created_at   DateTime @db.Timestamptz(6)
  updated_at   DateTime @db.Timestamptz(6)
  payments     payments @relation(fields: [payment_id], references: [payment_id], onDelete: Cascade)
}

model services {
  service_id  Int        @id @default(autoincrement())
  name        String     @db.VarChar(100)
  description String?
  base_price  Decimal    @db.Decimal(10, 2)
  created_at  DateTime   @db.Timestamptz(6)
  updated_at  DateTime   @db.Timestamptz(6)
  bookings    bookings[]
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model token_blacklist_blacklistedtoken {
  id                               BigInt                           @id @default(autoincrement())
  blacklisted_at                   DateTime                         @db.Timestamptz(6)
  token_id                         BigInt                           @unique
  token_blacklist_outstandingtoken token_blacklist_outstandingtoken @relation(fields: [token_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "token_blacklist_blacklistedtoken_token_id_3cc7fe56_fk")
}

model token_blacklist_outstandingtoken {
  id                               BigInt                            @id @default(autoincrement())
  token                            String
  created_at                       DateTime?                         @db.Timestamptz(6)
  expires_at                       DateTime                          @db.Timestamptz(6)
  user_id                          BigInt?
  jti                              String                            @unique(map: "token_blacklist_outstandingtoken_jti_hex_d9bdf6f7_uniq") @db.VarChar(255)
  token_blacklist_blacklistedtoken token_blacklist_blacklistedtoken?

  @@index([jti], map: "token_blacklist_outstandingtoken_jti_hex_d9bdf6f7_like")
  @@index([user_id], map: "token_blacklist_outstandingtoken_user_id_83bc629a")
}

model users {
  id                 Int                  @id @default(autoincrement())
  email              String               @unique @db.VarChar(255)
  password           String               @db.VarChar(255)
  first_name         String               @db.VarChar(150)
  last_name          String               @db.VarChar(150)
  phone_number       String?              @db.VarChar(20)
  user_type          enum_users_user_type @default(pet_owner)
  profile_picture    String?              @db.VarChar(255)
  address            String?              @db.VarChar(255)
  city               String?              @db.VarChar(100)
  emergency_contact_name String?          @db.VarChar(100)
  emergency_contact_number String?        @db.VarChar(20)
  is_profile_complete Boolean             @default(false)
  email_verified     Boolean?             @default(false)
  is_active          Boolean?             @default(true)
  is_staff           Boolean?             @default(false)
  is_superuser       Boolean?             @default(false)
  date_joined        DateTime?            @db.Timestamptz(6)
  last_login         DateTime?            @db.Timestamptz(6)
  activity_logs      activity_logs[]
  bookings           bookings[]
  chat_conversations chat_conversations[]
  contact_messages   contact_messages[]
  emergency_requests emergency_requests[]
  notifications      notifications[]
  password_resets    password_resets[]
  pets               pets[]
  public_forum       public_forum[]
  reviews            reviews[]
  email_verifications email_verifications[]
  user_settings      user_settings?
}

model wellness_timeline {
  timeline_id Int      @id @default(autoincrement())
  pet_id      Int
  date        DateTime @db.Timestamptz(6)
  type        String   @db.VarChar(50)
  title       String   @db.VarChar(200)
  description String?
  next_due_date DateTime? @db.Timestamptz(6)
  created_at  DateTime @db.Timestamptz(6)
  updated_at  DateTime @db.Timestamptz(6)
  pets        pets     @relation(fields: [pet_id], references: [pet_id], onDelete: Cascade)
}

model notifications {
  notification_id Int      @id @default(autoincrement())
  user_id         Int
  type            String   @default("booking_created") @db.VarChar(50)
  title           String?  @db.VarChar(255)
  message         String   @db.Text
  reference_type  String?  @db.VarChar(50)
  reference_id    Int?
  is_read         Boolean  @default(false)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)
  users           users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, is_read], name: "idx_notifications_user_read")
  @@index([reference_type, reference_id], name: "idx_notifications_reference")
}

model contact_messages {
  contact_id Int                          @id @default(autoincrement())
  user_id    Int?
  full_name  String                       @db.VarChar(150)
  email        String                       @db.VarChar(255)
  phone_number String?                      @db.VarChar(50)
  location     String?                      @db.VarChar(255)
  subject      String                       @db.VarChar(255)
  message    String
  status     enum_contact_messages_status @default(unread)
  created_at DateTime                     @db.Timestamptz(6)
  updated_at DateTime                     @db.Timestamptz(6)
  users      users?                       @relation(fields: [user_id], references: [id])
}

model reviews {
  review_id              Int       @id @default(autoincrement())
  booking_id             Int       @unique
  user_id                Int
  pet_id                 Int?
  service_type           String    @db.VarChar(100)
  rating_service         Int
  rating_staff           Int
  rating_cleanliness     Int
  rating_value           Int
  rating_communication   Int
  rating_pet_condition   Int
  overall_rating         Decimal   @db.Decimal(2, 1)
  review_text            String?   @db.Text
  photos                 String?   @db.VarChar(1000)
  is_verified            Boolean   @default(true)
  is_approved            Boolean   @default(false)
  is_featured            Boolean   @default(false)
  admin_response         String?   @db.Text
  admin_response_date    DateTime? @db.Timestamptz(6)
  helpful_count          Int       @default(0)
  created_at             DateTime  @default(now()) @db.Timestamptz(6)
  updated_at             DateTime  @default(now()) @db.Timestamptz(6)
  bookings               bookings  @relation(fields: [booking_id], references: [booking_id], onDelete: Cascade)
  users                  users     @relation(fields: [user_id], references: [id], onDelete: NoAction)
  pets                   pets?     @relation(fields: [pet_id], references: [pet_id], onDelete: Cascade)

  @@index([user_id], name: "idx_reviews_user")
  @@index([is_approved, is_featured], name: "idx_reviews_approved_featured")
  @@index([service_type], name: "idx_reviews_service_type")
}

model chat_conversations {
  conversation_id String                @id @default(uuid()) @db.Uuid
  user_id         Int
  title           String?               @db.VarChar(255)
  created_at      DateTime              @default(now()) @db.Timestamptz(6)
  updated_at      DateTime              @default(now()) @db.Timestamptz(6)
  last_message_at DateTime              @default(now()) @db.Timestamptz(6)
  users           users                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  messages        chat_messages[]

  @@index([user_id], name: "idx_chat_conversations_user")
  @@index([user_id, last_message_at], name: "idx_chat_conversations_user_last_message")
}

model chat_messages {
  message_id      Int                @id @default(autoincrement())
  conversation_id String             @db.Uuid
  role            String             @db.VarChar(20)
  content         String             @db.Text
  created_at      DateTime           @default(now()) @db.Timestamptz(6)
  conversation    chat_conversations @relation(fields: [conversation_id], references: [conversation_id], onDelete: Cascade)

  @@index([conversation_id], name: "idx_chat_messages_conversation")
  @@index([conversation_id, created_at], name: "idx_chat_messages_conversation_created")
}

model user_settings {
  settings_id             Int      @id @default(autoincrement())
  user_id                 Int      @unique
  theme                   String   @default("light") @db.VarChar(20)
  email_notifications     Boolean  @default(true)
  sms_notifications       Boolean  @default(false)
  activity_updates        Boolean  @default(true)
  booking_reminders       Boolean  @default(true)
  created_at              DateTime @default(now()) @db.Timestamptz(6)
  updated_at              DateTime @default(now()) @db.Timestamptz(6)
  users                   users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], name: "idx_user_settings_user")
}

enum enum_bookings_status {
  pending
  confirmed
  completed
  cancelled
}

enum enum_emergency_requests_status {
  pending
  in_progress
  resolved
  cancelled
}

enum enum_users_user_type {
  pet_owner
  admin
  staff
}

enum enum_contact_messages_status {
  unread
  read
}

enum enum_bookings_booking_status {
  pending
  approved
  confirmed
  completed
  rejected
  cancelled
}

enum enum_bookings_payment_status {
  unpaid
  pending_payment
  paid
  failed
}
